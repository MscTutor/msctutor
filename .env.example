# ══════════════════════════════════════════════
# MscTutor — Environment Variables
# Copy this file to .env.local for development
# Add to Vercel Dashboard for production
# ══════════════════════════════════════════════

# ── APP (REQUIRED) ──────────────────────────
NEXT_PUBLIC_APP_URL=https://msctutor.in
NEXT_PUBLIC_APP_NAME=MscTutor
NODE_ENV=production

# ── AI (REQUIRED for AI features) ──────────
# Get from: platform.deepseek.com (FREE $5 credit on signup)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── FIREBASE AUTH (REQUIRED for login) ─────
# Get from: console.firebase.google.com
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=msctutor.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=msctutor
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=msctutor.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123:web:abc123
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BNxxxxxxxxxxxxxxx

# Firebase Admin (for server-side auth verification)
# Convert JSON to base64: base64 -i serviceAccountKey.json
FIREBASE_ADMIN_SDK_JSON=eyJxxxxx...

# Admin UID (your Firebase UID for admin panel access)
ADMIN_FIREBASE_UID=your-firebase-uid-here

# ── DATABASE (RECOMMENDED) ──────────────────
# Free: PlanetScale (planetscale.com) or Railway (railway.app)
DATABASE_URL=mysql://user:password@host/msctutor?ssl={"rejectUnauthorized":true}

# ── PAYMENTS (OPTIONAL) ─────────────────────
# Razorpay (India) - razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx

# Stripe (International) - stripe.com
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ── FILE STORAGE (OPTIONAL) ─────────────────
# Cloudflare R2 (free 10GB) - cloudflare.com/r2
R2_ACCOUNT_ID=xxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxx
R2_BUCKET_NAME=msctutor-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── EMAIL (OPTIONAL) ────────────────────────
# Resend (free 3000/month) - resend.com
RESEND_API_KEY=re_xxxxxxxxxx
EMAIL_FROM=noreply@msctutor.in

# ── CACHE (OPTIONAL) ────────────────────────
# Upstash Redis (free 10000 req/day) - upstash.com
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxx

# ── SOCIAL LINKS (OPTIONAL) ─────────────────
NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@msctutor
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/msctutor
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/msctutor
NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=in.msctutor
